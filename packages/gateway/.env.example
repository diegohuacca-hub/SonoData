# ─── Gateway SonoData TEA — variables de entorno ─────────────────────────────
# Copia este archivo como .env y rellena con tus valores

# Firebase
FIREBASE_PROJECT_ID=sonodata-543f4
FIREBASE_API_KEY=AIzaSyAVgKsiTWEnjHaII53CAXKYZLi4XeQL6Ts
FIREBASE_DATABASE_URL=https://sonodata-543f4-default-rtdb.firebaseio.com

# Alumno activo en esta sesión
ALUMNO_ID=alumno_001
FAMILIA_ID=familia_001

# Umbrales del alumno (se sobreescriben desde Firestore si existen)
UMBRAL_DB=75
UMBRAL_FC=100

# Audio — dejar vacío para usar micrófono por defecto del sistema
# Si usas WO Mic, el celular aparece como dispositivo de audio en Windows
AUDIO_DEVICE_INDEX=

# BLE — dirección MAC de la Mi Band (se descubre automáticamente si está vacío)
MIBAND_MAC=

# Cámara — 0 = cámara por defecto, 1 = segunda cámara (DroidCam)
CAMARA_INDEX=0

# Intervalo de envío a Firebase (segundos)
INTERVALO_ENVIO=1
